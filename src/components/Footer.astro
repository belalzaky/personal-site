---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer-inner">
    <span class="footer-name">Belal Zaky — building with data, in public · © {year}</span>
    <nav class="footer-links" aria-label="Social links">
      <a href="https://linkedin.com/in/belalzaky" class="footer-link" target="_blank" rel="noopener noreferrer">LinkedIn</a>
      <span class="footer-sep" aria-hidden="true">·</span>
      <a href="https://github.com/belalzaky" class="footer-link" target="_blank" rel="noopener noreferrer">GitHub</a>
      <span class="footer-sep" aria-hidden="true">·</span>
      <a href="https://belalzaky.substack.com" class="footer-link" target="_blank" rel="noopener noreferrer">Substack</a>
      <span class="footer-sep" aria-hidden="true">·</span>
      <a href="mailto:belal4606@gmail.com" class="footer-link">Email</a>
    </nav>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--color-border);
    padding-block: var(--space-8);
    margin-top: var(--space-24);
  }

  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .footer-name,
  .footer-link {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  .footer-links {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .footer-link {
    text-decoration: none;
    transition: color var(--dur) var(--ease);
  }

  .footer-link:hover {
    color: var(--color-text);
  }

  .footer-sep {
    color: var(--color-text-subtle);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
  }
</style>
