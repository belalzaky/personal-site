---
---

<section class="hero">
  <div class="container hero-inner">
    <h1 class="hero-headline animate-in">Belal Zaky</h1>
    <p class="hero-subline animate-in animate-in-delay-1">
      Curious about how medicine works — and what its data can tell us.
    </p>
    <nav class="hero-actions animate-in animate-in-delay-2" aria-label="Primary links">
      <a href="/projects" class="btn btn-primary">Projects</a>
      <a href="/writing" class="btn btn-ghost">Writing</a>
      <a href="/about" class="btn btn-ghost">About</a>
    </nav>
    <p class="hero-now animate-in animate-in-delay-3">
      Now — first year at King's, teaching myself statistics and R, and turning each project I build into something I write about.
    </p>
  </div>
</section>

<style>
  .hero {
    padding-top: var(--space-24);
    padding-bottom: var(--space-24);
  }

  @media (max-width: 640px) {
    .hero {
      padding-top: var(--space-16);
      padding-bottom: var(--space-16);
    }
  }

  .hero-inner {
    max-width: 680px;
  }

  .hero-headline {
    font-family: var(--font-mono);
    font-size: var(--text-3xl);
    font-weight: 500;
    line-height: 1.1;
    letter-spacing: -0.01em;
    color: var(--color-text);
    margin-bottom: var(--space-4);
  }

  @media (max-width: 640px) {
    .hero-headline {
      font-size: var(--text-2xl);
    }
  }

  .hero-subline {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    line-height: 1.65;
    max-width: 52ch;
    margin-bottom: var(--space-6);
  }

  .hero-actions {
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
    margin-bottom: var(--space-8);
  }

  .hero-now {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    letter-spacing: 0.01em;
    max-width: 58ch;
    line-height: 1.7;
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-border);
  }

  /* Buttons */
  .btn {
    display: inline-flex;
    align-items: center;
    padding: 6px 14px;
    border-radius: var(--radius);
    font-size: var(--text-xs);
    font-weight: 500;
    text-decoration: none;
    transition:
      background var(--dur) var(--ease),
      color var(--dur) var(--ease),
      border-color var(--dur) var(--ease),
      transform var(--dur) var(--ease);
    border: 1px solid transparent;
    white-space: nowrap;
    line-height: 1;
  }

  .btn:hover {
    transform: translateY(-1px);
  }

  .btn-primary {
    background: var(--color-accent);
    color: #ffffff;
    border-color: var(--color-accent);
  }

  .btn-primary:hover {
    background: var(--color-accent-hover);
    border-color: var(--color-accent-hover);
    color: #ffffff;
  }

  .btn-ghost {
    background: transparent;
    color: var(--color-text);
    border-color: var(--color-border);
  }

  .btn-ghost:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }
</style>
