---
import Base from '../../layouts/Base.astro';
import WritingItem from '../../components/WritingItem.astro';
import { getCollection } from 'astro:content';

const SUBSTACK_HOME = 'https://belalzaky.substack.com';

const posts = await getCollection('posts');
const sorted = posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const isPublished = (url?: string) => !!url && url.replace(/\/$/, '') !== SUBSTACK_HOME;

// Featured = most recent published post
const featuredPost = sorted.find(p => isPublished(p.data.url));

// Remaining list = everything except the featured post, newest first
const listPosts = sorted.filter(p => p !== featuredPost);

const featuredDate = featuredPost?.data.date.toLocaleDateString('en-GB', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Base title="Writing — Belal Zaky" description="Learning in public — building data skills for drug safety, one project at a time.">
  <div class="page container container--prose">

    <header class="page-header">
      <p class="page-eyebrow">Notes</p>
      <h1 class="page-title">Writing</h1>
      <p class="page-intro">
        Learning in public — building data skills for drug safety, one project at a time.
      </p>
      <a
        href="https://belalzaky.substack.com"
        class="substack-btn"
        target="_blank"
        rel="noopener noreferrer"
      >
        Subscribe on Substack →
      </a>
    </header>

    {featuredPost && (
      <a
        href={featuredPost.data.url}
        class="featured-card"
        target="_blank"
        rel="noopener noreferrer"
      >
        <p class="featured-label">Latest</p>
        <time class="featured-date" datetime={featuredPost.data.date.toISOString()}>
          {featuredDate}
        </time>
        <h2 class="featured-title">{featuredPost.data.title}</h2>
        {featuredPost.data.summary && (
          <p class="featured-summary">{featuredPost.data.summary}</p>
        )}
        <span class="featured-cta">Read on Substack ↗</span>
      </a>
    )}

    {!featuredPost && (
      <p class="no-published">Posts coming soon — subscribe above to be notified.</p>
    )}

    {listPosts.length > 0 && (
      <ul role="list" class="writing-list">
        {listPosts.map(post => (
          <WritingItem
            title={post.data.title}
            date={post.data.date}
            summary={post.data.summary}
            href={isPublished(post.data.url) ? post.data.url : undefined}
          />
        ))}
      </ul>
    )}

  </div>
</Base>

<style>
  .page {
    padding-top: var(--space-16);
    padding-bottom: var(--space-24);
  }

  /* Header */
  .page-header {
    margin-bottom: var(--space-12);
  }

  .page-eyebrow {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--color-text-muted);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: var(--space-3);
    max-width: none;
  }

  .page-title {
    font-family: var(--font-mono);
    font-size: var(--text-3xl);
    font-weight: 500;
    letter-spacing: -0.01em;
    line-height: 1.1;
    margin-bottom: var(--space-4);
  }

  @media (max-width: 640px) {
    .page-title {
      font-size: var(--text-2xl);
    }
  }

  .page-intro {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    line-height: 1.6;
    margin-bottom: var(--space-6);
  }

  .substack-btn {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 6px 14px;
    text-decoration: none;
    transition:
      color var(--dur) var(--ease),
      border-color var(--dur) var(--ease);
  }

  .substack-btn:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }

  /* Featured card */
  .featured-card {
    display: block;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: var(--space-8);
    margin-bottom: var(--space-8);
    text-decoration: none;
    transition: border-color var(--dur) var(--ease);
  }

  .featured-card:hover {
    border-color: var(--color-accent);
  }

  .featured-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--color-accent);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: var(--space-3);
    max-width: none;
  }

  .featured-date {
    display: block;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    letter-spacing: 0.02em;
    margin-bottom: var(--space-3);
  }

  .featured-title {
    font-family: var(--font-mono);
    font-size: var(--text-xl);
    font-weight: 500;
    letter-spacing: -0.01em;
    color: var(--color-text);
    line-height: 1.3;
    margin-bottom: var(--space-3);
    transition: color var(--dur) var(--ease);
  }

  .featured-card:hover .featured-title {
    color: var(--color-accent);
  }

  .featured-summary {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1.65;
    margin-bottom: var(--space-4);
    max-width: 56ch;
  }

  .featured-cta {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-accent);
    font-weight: 500;
    transition: color var(--dur) var(--ease);
  }

  .featured-card:hover .featured-cta {
    color: var(--color-accent-hover);
  }

  /* No published state */
  .no-published {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    font-style: italic;
    margin-bottom: var(--space-8);
  }

  /* List */
  .writing-list {
    list-style: none;
    border-top: 1px solid var(--color-border);
  }
</style>
