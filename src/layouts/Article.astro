---
import Base from './Base.astro';

interface Props {
  title: string;
  date: Date;
  dek?: string;
  tags?: string[];
}

const { title, date, dek, tags = [] } = Astro.props;

const formattedDate = date.toLocaleDateString('en-GB', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Base title={`${title} — Belal`}>
  <article class="article container container--prose">
    <header class="article-header">
      <div class="article-meta">
        <time datetime={date.toISOString()} class="article-date">{formattedDate}</time>
        {tags.length > 0 && (
          <ul class="article-tags" role="list">
            {tags.map(tag => (
              <li class="tag">{tag}</li>
            ))}
          </ul>
        )}
      </div>
      <h1 class="article-title">{title}</h1>
      {dek && <p class="article-dek">{dek}</p>}
    </header>

    <div class="prose">
      <slot />
    </div>
  </article>
</Base>

<style>
  .article {
    padding-top: var(--space-16);
    padding-bottom: var(--space-24);
  }

  .article-header {
    margin-bottom: var(--space-12);
    padding-bottom: var(--space-8);
    border-bottom: 1px solid var(--color-border);
  }

  .article-meta {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    margin-bottom: var(--space-4);
    flex-wrap: wrap;
  }

  .article-date {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    letter-spacing: 0.02em;
  }

  .article-tags {
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
    list-style: none;
  }

  .tag {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    background: var(--color-accent-soft);
    color: var(--color-accent);
    border-radius: var(--radius-sm);
    padding: 2px 8px;
  }

  .article-title {
    font-size: var(--text-3xl);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-4);
  }

  @media (max-width: 640px) {
    .article-title {
      font-size: var(--text-2xl);
    }
  }

  .article-dek {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    line-height: 1.6;
    max-width: 55ch;
  }
</style>
